# =============================================================================
# OpenVPN hub configuration.  Copy to `.env` and edit:  cp .env.example .env
# `.env` is gitignored; this template is the committed, canonical reference.
# All values are injected into the container (compose `env_file: .env`) and read
# by the in-container scripts. server.conf is rewritten on every start, so after
# editing just re-run ./scripts/deploy-prod.sh (or deploy-dev.sh).
#
# NOTE: env_file values are literal — no quotes, no spaces around `=`, and values
# with spaces are not supported here, so keep them single-token.
# =============================================================================

# --- Public endpoint ---------------------------------------------------------
# Public FQDN/IP of this VPS. Embedded in client .ovpn `remote` lines AND used
# as the server certificate CN (set once at first-run PKI generation).
SERVER_ADDRESS=changeme.example.com
SERVER_LISTENING_PORT=1194
OPENVPN_PROTO=udp

# --- Networks ----------------------------------------------------------------
# VPN client subnet (hub takes .1). Home LAN reachable behind pfSense.
OPENVPN_NETWORK=192.168.75.0
OPENVPN_HOST_NETWORK=192.168.74.0

# Dynamic-address pool. Clients WITHOUT a hardcoded IP are leased from this
# range; everything below POOL_START (.2-.127 here, the hub owns .1) is the
# static range for `generate_client.sh <name>` pins. Keeping the two ranges
# disjoint stops a dynamic client from grabbing an offline static client's
# address. Edit + redeploy to re-apply.
OPENVPN_POOL_START=192.168.75.128
OPENVPN_POOL_END=192.168.75.254

# DNS pushed to clients (typically a LAN resolver reachable over the tunnel).
VPN_DNS=192.168.74.200

# --- pfSense site peer -------------------------------------------------------
# Must EXACTLY match the CN of the cert pfSense connects with. The CCD file at
# /etc/openvpn/ccd/<this value> carries the iroute that binds the LAN subnet to
# the pfSense peer. CN mismatch = no LAN reachability.
INTRANET_PEER_CN=pfsense-site
# Fixed tunnel IP for the pfSense site client (must be in the static range, i.e.
# below OPENVPN_POOL_START). init_vpn.sh writes this as an `ifconfig-push` next
# to the iroute in ccd/<INTRANET_PEER_CN>. A bad/in-pool value falls back to a
# dynamic lease (logged).
INTRANET_TUNNEL_IP=192.168.75.2

# --- Certificate subject (first-run PKI + client certs only) -----------------
OPENVPN_COUNTRY=US
OPENVPN_PROVINCE=State
OPENVPN_CITY=City
OPENVPN_ORG=MyVPN
OPENVPN_EMAIL=admin@example.com
OPENVPN_OU=MyVPN_Unit

# --- Failover (legacy; keep 0 for a single hub) ------------------------------
SERVER_FALLBACK_PRIORITY=0
